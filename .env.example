# Copiar para .env:  copy .env.example .env

# PostgreSQL (docker compose up -d)
DATABASE_URL=postgresql://autocunha:autocunha@localhost:5432/rentacar
# Frota demo no arranque (API): true por omissão com DATABASE_URL
AUTO_SEED_DEMO=true
# true = limpa reservas/SOS e repõe frota a cada arranque (Railway demo)
AUTO_SEED_RESET=true

# API Server
PORT=5000
NODE_ENV=development

# Dashboard Vite
DASHBOARD_PORT=5173
BASE_PATH=/
