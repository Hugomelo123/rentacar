{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"const ok=(process.env.npm_config_user_agent||'').includes('pnpm')||(process.env.npm_execpath||'').includes('pnpm');if(!ok){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "node scripts/apply-schema.mjs",
    "db:seed": "pnpm --filter @workspace/db run seed",
    "setup:local": "pnpm db:up && node scripts/wait-for-db.mjs && pnpm db:push && pnpm db:seed",
    "dev:api": "pnpm --filter @workspace/api-server run dev:watch",
    "dev:web": "pnpm --filter @workspace/rentacar-dashboard run dev:local"
  },
  "private": true,
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "4.60.3",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.0",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
